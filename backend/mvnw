#!/bin/sh
# Maven Wrapper script
# Downloads and runs Maven if not already cached

set -e

MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6"
MAVEN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MAVEN_CMD" ]; then
    echo "Downloading Maven 3.9.6..."
    mkdir -p "$MAVEN_HOME"
    TEMP_FILE=$(mktemp)
    curl -fsSL "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip" -o "$TEMP_FILE"
    unzip -qo "$TEMP_FILE" -d "$HOME/.m2/wrapper/dists/"
    rm -f "$TEMP_FILE"
    # Fix: unzip creates apache-maven-3.9.6 inside dists
    if [ -d "$HOME/.m2/wrapper/dists/apache-maven-3.9.6" ]; then
        chmod +x "$MAVEN_CMD"
    fi
fi

exec "$MAVEN_CMD" "$@"
